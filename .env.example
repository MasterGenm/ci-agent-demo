# ===== 搜索/抓取 =====
TAVILY_API_KEY=tvly-xxx
# FIRECRAWL_API_KEY=fc-xxx   # M1.5+ 启用,M1 留空

# ===== LLM provider 选择 =====
# anthropic | openai
LLM_PROVIDER=anthropic

# --- Anthropic 路径 ---
# 官方:留空 ANTHROPIC_BASE_URL 即可
# 第三方 Anthropic 兼容代理:填 base_url(如 https://api.proxy.com)
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=

# --- OpenAI 兼容路径(DeepSeek / 智谱 / Moonshot / 火山方舟 / OpenRouter / OpenAI 官方)---
# 设置 LLM_PROVIDER=openai 后启用
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ===== Extractor 配置 =====
# 模型名要匹配你选的 provider:
#   anthropic 下:claude-haiku-4-5 / claude-sonnet-4-6 / claude-opus-4-7
#   openai 下:gpt-4o-mini / deepseek-chat / glm-4-air / moonshot-v1-8k / doubao-lite-32k ...
EXTRACTOR_MODEL=claude-haiku-4-5
EXTRACTOR_MAX_CONCURRENCY=4
EXTRACTOR_MAX_COST_USD=2.0
ANALYST_MAX_CONCURRENCY=4
# 仅对 reasoning 模型(deepseek-v4-flash / deepseek-r1 / qwq 等)生效。
# 默认 false:M2 抽取不需要思考,关掉省一倍成本和延迟。
# 非 reasoning 模型会忽略此参数。
EXTRACTOR_ENABLE_THINKING=false

# ===== Vision LLM fallback（可选，用于突破反爬页面截图识别）=====
# 填入 key 后自动启用；不填则跳过 Vision，只用 Playwright 文字提取
# 支持任何 OpenAI 兼容的 Vision 模型
# Kimi（推荐，国内速度快）：
# VISION_API_KEY=sk-xxx
# VISION_BASE_URL=https://api.moonshot.cn/v1
# VISION_MODEL=moonshot-v1-128k-vision-preview
# OpenAI：
# VISION_API_KEY=sk-xxx
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini

# ===== 数据存储 =====
DB_PATH=data/cs_mvp.db
RUNS_DIR=runs

# ===== Langfuse Cloud Observability(可选,v1.5) =====
# 不设置以下变量时,系统行为等价 v1.4.1 baseline,只写本地 trace/artifact。
# 只支持 Langfuse Cloud SaaS;本项目不自部署 Langfuse。
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
